# ============================================================================
# Lithosphere MAINNET Environment Configuration
# ============================================================================
# Source: Validator Infrastructure Team Handover (Feb 2026)
# ============================================================================
# SECURITY: Passwords marked <STRONG_PASSWORD> MUST be set via GitHub Secrets
# or a secrets manager — NEVER commit real credentials.
# ============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# General
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=production
ENVIRONMENT=mainnet
LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────────────────────
# Chain Parameters (canonical — do not change)
# ─────────────────────────────────────────────────────────────────────────────
CHAIN_ID=lithosphere_700777-2
CHAIN_NAME=Lithosphere
LITHO_CHAIN_ID=700777
# Base denom: ulitho (18 decimals — 1 LITHO = 10^18 ulitho)

# ─────────────────────────────────────────────────────────────────────────────
# Live Network Endpoints — Public domains (TLS via Nginx on Sentry 1)
# ─────────────────────────────────────────────────────────────────────────────
# Cosmos RPC
RPC_URL=https://rpc.litho.ai
LITHO_RPC_URL=https://rpc.litho.ai
# Cosmos REST / LCD
LITHO_LCD_URL=https://api.litho.ai
# gRPC (use domain once TLS proxy is configured; fallback to direct IP)
GRPC_URL=grpc.litho.ai:9090
# EVM JSON-RPC — rpc.litho.ai is the live chain (lithosphere_700777-2). NLB is stale (700777-1).
EVM_RPC_URL=https://rpc.litho.ai
# EVM WebSocket (Cosmos WebSocket confirmed live via Nginx on Sentry 1)
EVM_WS_URL=wss://rpc.litho.ai/websocket
# Multi-endpoint failover (HTTPS primary, domain fallback)
RPC_ENDPOINTS=https://rpc.litho.ai,http://52.41.98.79:26657
GRPC_ENDPOINTS=31.97.39.138:9090,52.41.98.79:9090

# ─────────────────────────────────────────────────────────────────────────────
# Database (AWS RDS — NOT the local postgres container)
# Credentials managed via AWS Secrets Manager:
#   arn:aws:secretsmanager:us-east-1:261737251952:secret/litho-mainnet-db-credentials
# ─────────────────────────────────────────────────────────────────────────────
POSTGRES_DB=lithoscan
POSTGRES_USER=lithoscan_admin
POSTGRES_PASSWORD=<FROM_AWS_SECRETS_MANAGER>
POSTGRES_PORT=5432
# DATABASE_URL is overwritten at deploy time by the Inject RDS step in deploy-simple.yaml
# Password is injected from AWS Secrets Manager at deploy time. If OIDC fails, the validator
# team must manually set the password in /opt/lithosphere/Makalu/.env on the indexer.
DATABASE_URL=postgresql://lithoscan_admin:<FROM_AWS_SECRETS_MANAGER>@litho-mainnet-postgres-db.c4tmmiw8ujju.us-east-1.rds.amazonaws.com:5432/lithoscan?sslmode=require
# Required: RDS cert chain uses AWS CA not in Node default trust store
NODE_TLS_REJECT_UNAUTHORIZED=0

# ─────────────────────────────────────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=<STRONG_PASSWORD>
REDIS_PORT=6379

# ─────────────────────────────────────────────────────────────────────────────
# API Service
# ─────────────────────────────────────────────────────────────────────────────
API_PORT=4000
API_HOST=0.0.0.0
GRAPHQL_PLAYGROUND=false
CORS_ORIGINS=https://makalu.litho.ai,https://status.litho.ai
PROMETHEUS_ENABLED=true
METRICS_PORT=9090

# ─────────────────────────────────────────────────────────────────────────────
# Indexer
# ─────────────────────────────────────────────────────────────────────────────
INDEXER_START_BLOCK=1
START_BLOCK=1
INDEXER_BATCH_SIZE=500
BATCH_SIZE=500
INDEXER_CONFIRMATIONS=12
INDEXER_POLL_INTERVAL=3000
# Set to 1 only for initial sync; 0 = resume from last indexed block on restart
FORCE_REINDEX=0

# ─────────────────────────────────────────────────────────────────────────────
# Explorer Frontend
# ─────────────────────────────────────────────────────────────────────────────
EXPLORER_PORT=3100
NEXT_PUBLIC_API_URL=https://makalu.litho.ai/api
NEXT_PUBLIC_GRAPHQL_URL=https://makalu.litho.ai/api/graphql
NEXT_PUBLIC_RPC_URL=https://rpc.litho.ai
# TODO: Update to wss:// domain once Validator Team confirms Nginx WSS proxy is live
NEXT_PUBLIC_WS_URL=ws://54.163.248.63:8546
NEXT_PUBLIC_CHAIN_ID=lithosphere_700777-2
NEXT_PUBLIC_CHAIN_NAME=Lithosphere
NEXT_PUBLIC_SITE_URL=https://makalu.litho.ai
NEXT_PUBLIC_EXPLORER_TITLE=Lithosphere Explorer

# ─────────────────────────────────────────────────────────────────────────────
# Network Status / Health Monitor
# ─────────────────────────────────────────────────────────────────────────────
CHECK_INTERVAL=5000

# ─────────────────────────────────────────────────────────────────────────────
# Monitoring (Grafana on :3001 — explorer is on :3100)
# ─────────────────────────────────────────────────────────────────────────────
GRAFANA_PORT=3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=<STRONG_PASSWORD>
PROMETHEUS_PORT=9091

# ─────────────────────────────────────────────────────────────────────────────
# Container Registry
# ─────────────────────────────────────────────────────────────────────────────
REGISTRY=ghcr.io
IMAGE_NAME=kajlabs/lithosphere
IMAGE_TAG=mainnet

# ─────────────────────────────────────────────────────────────────────────────
# Faucet (Makalu testnet token dispenser)
# FAUCET_PRIVATE_KEY is injected at deploy time from GitHub Secret — never commit a real key here
# ─────────────────────────────────────────────────────────────────────────────
FAUCET_PRIVATE_KEY=<INJECTED_BY_CI>
FAUCET_RPC_URL=https://rpc.litho.ai
FAUCET_CHAIN_ID=700777
FAUCET_DRIP_AMOUNT=1
FAUCET_NATIVE_ALLOWED_AMOUNTS=1,2,5
FAUCET_COOLDOWN_HOURS=24
# LEP100 tokens available in faucet (JSON array). Use the 2026-04-24 funded deployment.
# Faucet wallet: 0x43593dC799d432CB6382ae20186Ba5356AC7D271
FAUCET_TOKEN_ASSETS=[{"id":"wlitho","name":"Wrapped Lithosphere","symbol":"wLITHO","contractAddress":"0x599a7E135f1790ae117b4EdDc0422D24Bc766161","decimals":18,"allowedAmounts":["10","25","50"],"defaultAmount":"10"},{"id":"litbtc","name":"Lithosphere LitBTC","symbol":"LitBTC","contractAddress":"0xC4645CA5411D6E27556780AB4cdd0DF7e609df74","decimals":18,"allowedAmounts":["10","25","50"],"defaultAmount":"10"},{"id":"lax","name":"Lithosphere Algo","symbol":"LAX","contractAddress":"0x1Cde2Ca6c2ab8622003ebe06e382bC07850d4B8d","decimals":18,"allowedAmounts":["10","25","50"],"defaultAmount":"10"},{"id":"jot","name":"Jot Art","symbol":"JOT","contractAddress":"0xEF2f35f6d0fb7DC9E87b8ca8252AE2E6ffb2a25e","decimals":18,"allowedAmounts":["10","25","50"],"defaultAmount":"10"},{"id":"colle","name":"Colle AI","symbol":"COLLE","contractAddress":"0x10D4BB600c96e9243E2f50baFED8b2478F25af61","decimals":18,"allowedAmounts":["10","25","50"],"defaultAmount":"10"},{"id":"image","name":"Imagen Network","symbol":"IMAGE","contractAddress":"0xAcD98E323968647936887aD4934e64B01060727e","decimals":18,"allowedAmounts":["10","25","50"],"defaultAmount":"10"},{"id":"agii","name":"AGII","symbol":"AGII","contractAddress":"0x10052B8ccD2160b8F9880C6b4F5DD117fF253B1c","decimals":18,"allowedAmounts":["10","25","50"],"defaultAmount":"10"},{"id":"bldr","name":"Built AI","symbol":"BLDR","contractAddress":"0x798eD6bFc5bfCFc60938d5098825b354427A0786","decimals":18,"allowedAmounts":["10","25","50"],"defaultAmount":"10"},{"id":"fgpt","name":"FurGPT","symbol":"FGPT","contractAddress":"0x151ef362eA96853702Cc5e7728107e3961fbD22e","decimals":18,"allowedAmounts":["10","25","50"],"defaultAmount":"10"},{"id":"musa","name":"Mansa AI","symbol":"MUSA","contractAddress":"0xDB829befCF8E582379E2c034FA2589b8D2EA1c5D","decimals":18,"allowedAmounts":["10","25","50"],"defaultAmount":"10"}]

# ─────────────────────────────────────────────────────────────────────────────
# Feature Flags
# ─────────────────────────────────────────────────────────────────────────────
CONTRACTS_ENABLED=false
MONITORING_ENABLED=true
PROXY_ENABLED=false
