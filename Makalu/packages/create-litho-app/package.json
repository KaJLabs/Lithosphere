{
  "name": "create-litho-app",
  "version": "0.1.0",
  "description": "Official CLI for scaffolding Lithosphere developer-preview projects",
  "license": "MIT",
  "author": "Lithosphere Team",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KaJLabs/lithosphere.git",
    "directory": "Makalu/packages/create-litho-app"
  },
  "homepage": "https://github.com/KaJLabs/lithosphere/tree/main/Makalu/packages/create-litho-app",
  "bugs": {
    "url": "https://github.com/KaJLabs/lithosphere/issues"
  },
  "type": "module",
  "bin": {
    "create-litho-app": "./dist/index.cjs"
  },
  "main": "./dist/index.cjs",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && node scripts/prepare-package.mjs",
    "dev": "tsup --watch",
    "start": "node dist/index.cjs",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepack": "pnpm run build",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "fs-extra": "^11.2.0",
    "inquirer": "^9.2.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "rimraf": "^5.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "lithosphere",
    "developer-preview",
    "cli",
    "scaffold",
    "generator",
    "create-app"
  ]
}
